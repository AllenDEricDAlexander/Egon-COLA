#set( $symbol_dollar = '$' )
<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Spring Environment values keep deployment policy outside this XML. -->
    <springProperty scope="context"
                    name="APP_NAME"
                    source="spring.application.name"
                    defaultValue="application"/>
    <springProperty scope="context"
                    name="APP_ENV"
                    source="spring.profiles.active"
                    defaultValue="default"/>
    <springProperty scope="context"
                    name="LOG_HOME"
                    source="logging.file.path"
                    defaultValue="./logs"/>
    <springProperty scope="context"
                    name="INSTANCE_NAME"
                    source="app.logging.instance-name"
                    defaultValue="local"/>
    <springProperty scope="context"
                    name="ROOT_LOG_LEVEL"
                    source="logging.level.root"
                    defaultValue="INFO"/>
    <springProperty scope="context"
                    name="MAX_FILE_SIZE"
                    source="logging.logback.rollingpolicy.max-file-size"
                    defaultValue="100MB"/>
    <springProperty scope="context"
                    name="MAX_HISTORY"
                    source="logging.logback.rollingpolicy.max-history"
                    defaultValue="30"/>
    <springProperty scope="context"
                    name="TOTAL_SIZE_CAP"
                    source="logging.logback.rollingpolicy.total-size-cap"
                    defaultValue="10GB"/>
    <springProperty scope="context"
                    name="CLEAN_HISTORY_ON_START"
                    source="logging.logback.rollingpolicy.clean-history-on-start"
                    defaultValue="false"/>
    <springProperty scope="context"
                    name="ERROR_TOTAL_SIZE_CAP"
                    source="app.logging.error-total-size-cap"
                    defaultValue="2GB"/>
    <springProperty scope="context"
                    name="ASYNC_QUEUE_SIZE"
                    source="app.logging.async.queue-size"
                    defaultValue="8192"/>
    <springProperty scope="context"
                    name="ASYNC_DISCARDING_THRESHOLD"
                    source="app.logging.async.discarding-threshold"
                    defaultValue="0"/>
    <springProperty scope="context"
                    name="ASYNC_NEVER_BLOCK"
                    source="app.logging.async.never-block"
                    defaultValue="false"/>
    <springProperty scope="context"
                    name="ASYNC_MAX_FLUSH_TIME"
                    source="app.logging.async.max-flush-time"
                    defaultValue="5000"/>
    <springProperty scope="context"
                    name="CONSOLE_STRUCTURED_FORMAT"
                    source="logging.structured.format.console"
                    defaultValue="ecs"/>

    <property name="LOG_DIR"
              value="${symbol_dollar}{LOG_HOME}/${symbol_dollar}{APP_NAME}/${symbol_dollar}{INSTANCE_NAME}"/>

    <property name="MDC_LOG_PATTERN"
              value="traceId=%X{traceId:-} spanId=%X{spanId:-} requestId=%X{requestId:-} tenantId=%X{tenantId:-} userId=%X{userId:-} entId=%X{entId:-}"/>
    <property name="FILE_LOG_PATTERN"
              value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level app=${symbol_dollar}{APP_NAME} env=${symbol_dollar}{APP_ENV} instance=${symbol_dollar}{INSTANCE_NAME} pid=${symbol_dollar}{PID} [%thread] %logger{48} ${symbol_dollar}{MDC_LOG_PATTERN} %kvp - %msg%n${symbol_dollar}{LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>
    <property name="CONSOLE_LOG_PATTERN"
              value="%clr(%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}){faint} %clr(%-5level) %clr(${symbol_dollar}{PID}){magenta} %clr([%thread]){faint} %clr(%logger{40}){cyan} ${symbol_dollar}{MDC_LOG_PATTERN} %kvp %clr(:){faint} %msg%n${symbol_dollar}{LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>${symbol_dollar}{CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <springProfile name="(local | dev | test) &amp; !k8s">
        <root level="${symbol_dollar}{ROOT_LOG_LEVEL}">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- Kubernetes delegates rotation to the container runtime or collector. -->
    <springProfile name="k8s">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="org.springframework.boot.logging.logback.StructuredLogEncoder">
                <format>${symbol_dollar}{CONSOLE_STRUCTURED_FORMAT}</format>
                <charset>UTF-8</charset>
            </encoder>
        </appender>
        <root level="${symbol_dollar}{ROOT_LOG_LEVEL}">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
    </springProfile>

    <!-- Traditional deployments keep a durable main file and ERROR mirror. -->
    <springProfile name="!local &amp; !dev &amp; !test &amp; !k8s">
        <appender name="APP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${symbol_dollar}{LOG_DIR}/application.log</file>
            <append>true</append>
            <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                <pattern>${symbol_dollar}{FILE_LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${symbol_dollar}{LOG_DIR}/archive/application.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>${symbol_dollar}{MAX_FILE_SIZE}</maxFileSize>
                <maxHistory>${symbol_dollar}{MAX_HISTORY}</maxHistory>
                <totalSizeCap>${symbol_dollar}{TOTAL_SIZE_CAP}</totalSizeCap>
                <cleanHistoryOnStart>${symbol_dollar}{CLEAN_HISTORY_ON_START}</cleanHistoryOnStart>
            </rollingPolicy>
        </appender>

        <appender name="ASYNC_APP_FILE" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>${symbol_dollar}{ASYNC_QUEUE_SIZE}</queueSize>
            <discardingThreshold>${symbol_dollar}{ASYNC_DISCARDING_THRESHOLD}</discardingThreshold>
            <neverBlock>${symbol_dollar}{ASYNC_NEVER_BLOCK}</neverBlock>
            <includeCallerData>false</includeCallerData>
            <maxFlushTime>${symbol_dollar}{ASYNC_MAX_FLUSH_TIME}</maxFlushTime>
            <appender-ref ref="APP_FILE"/>
        </appender>

        <!-- Keep the critical ERROR path synchronous when the async queue is busy. -->
        <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${symbol_dollar}{LOG_DIR}/error.log</file>
            <append>true</append>
            <filter class="ch.qos.logback.classic.filter.LevelFilter">
                <level>ERROR</level>
                <onMatch>ACCEPT</onMatch>
                <onMismatch>DENY</onMismatch>
            </filter>
            <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                <pattern>${symbol_dollar}{FILE_LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${symbol_dollar}{LOG_DIR}/archive/error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>${symbol_dollar}{MAX_FILE_SIZE}</maxFileSize>
                <maxHistory>${symbol_dollar}{MAX_HISTORY}</maxHistory>
                <totalSizeCap>${symbol_dollar}{ERROR_TOTAL_SIZE_CAP}</totalSizeCap>
                <cleanHistoryOnStart>${symbol_dollar}{CLEAN_HISTORY_ON_START}</cleanHistoryOnStart>
            </rollingPolicy>
        </appender>

        <root level="${symbol_dollar}{ROOT_LOG_LEVEL}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_APP_FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>
</configuration>
